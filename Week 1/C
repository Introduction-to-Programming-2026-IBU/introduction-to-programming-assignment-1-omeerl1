#include <cs50.h>
#include <stdio.h>

int main(void)
{
    int height;
    // Force the user to give a height between 1 and 8
    do
    {
        height = get_int("Height: ");
    }
    while (height < 1 || height > 8);

    // Build the rows
    for (int i = 0; i < height; i++)
    {
        // Print leading spaces
        for (int j = 0; j < height - i - 1; j++)
        {
            printf(" ");
        }
        // Print hashes
        for (int k = 0; k < i + 1; k++)
        {
            printf("#");
        }
        // Move to the next line
        printf("\n");
    }
}
